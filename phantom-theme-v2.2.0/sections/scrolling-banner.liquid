{% style %}
  .scrolling-banner--{{ section.id }} {
    --move-speed: {{ section.settings.speed }}s;
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
  }
  .scrolling-banner--{{ section.id }} .scrolling-banner__item {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .scrolling-banner--{{ section.id }} .scrolling-banner__item img,
  .scrolling-banner--{{ section.id }} .scrolling-banner__item svg {
    display: block;
  }
  .scrolling-banner--{{ section.id }} .scrolling-banner__item a {
    display: block;
    line-height: 0;
  }
  .scrolling-banner--{{ section.id }} .scrolling-banner__divider {
    display: inline-flex;
    align-items: center;
    margin: 0 8px;
  }
  .scrolling-banner--{{ section.id }} .scrolling-banner__text {
    white-space: nowrap;
  }
  .scrolling-banner--{{ section.id }} .scrolling-banner__icon {
    display: inline-flex;
    align-items: center;
    vertical-align: middle;
  }
  .scrolling-banner--{{ section.id }} .scrolling-banner__placeholder {
    display: inline-block;
  }
{% endstyle %}

<div class="scrolling-text scrolling-banner scrolling-banner--{{ section.id }}">
  <div
    class="scrolling-text__inner scrolling-text__inner--{{ section.settings.direction }}"
    aria-hidden="true"
    tabindex="0"
    style="gap: {{ section.settings.gap }}px;"
  >
    {% for i in (1..10) %}
      {% for block in section.blocks %}
        <span class="scrolling-banner__item" {{ block.shopify_attributes }}>
          {% case block.type %}
            {% when 'text' %}
              <span class="scrolling-banner__text" style="font-size: {{ block.settings.font_size }}px;">
                {{ block.settings.text }}
              </span>
            {% when 'image' %}
              {% if block.settings.link %}
                <a href="{{ block.settings.link }}" tabindex="-1">
              {% endif %}
                {% if block.settings.image %}
                  <img
                    src="{{ block.settings.image | image_url: width: block.settings.image_width }}"
                    alt="{{ block.settings.image.alt | escape }}"
                    height="{{ block.settings.image_height }}"
                    width="{{ block.settings.image_width }}"
                    style="height: {{ block.settings.image_height }}px; width: auto;"
                    loading="lazy"
                  >
                {% else %}
                  <span class="scrolling-banner__placeholder" style="width: {{ block.settings.image_width }}px; height: {{ block.settings.image_height }}px; display: inline-block; background: #e0e0e0; border-radius: 4px;"></span>
                {% endif %}
              {% if block.settings.link %}
                </a>
              {% endif %}
            {% when 'icon' %}
              <span class="scrolling-banner__icon" style="font-size: {{ block.settings.icon_size }}px;">
                {%- render 'scrolling-banner-icon', icon: block.settings.icon -%}
              </span>
          {% endcase %}
        </span>
        {% if section.settings.show_divider %}
          <span class="scrolling-banner__divider" aria-hidden="true" style="color: {{ section.settings.divider_color }};">
            {%- render 'scrolling-banner-icon', icon: section.settings.divider_icon -%}
          </span>
        {% endif %}
      {% endfor %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Scrolling banner",
  "class": "index-section--flush",
  "settings": [
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed",
      "default": 200,
      "min": 50,
      "max": 400,
      "step": 10,
      "unit": "s"
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Direction",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Space between items",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show divider between items",
      "default": false
    },
    {
      "type": "select",
      "id": "divider_icon",
      "label": "Divider icon",
      "default": "star",
      "options": [
        { "value": "star", "label": "Star" },
        { "value": "dot", "label": "Dot" },
        { "value": "diamond", "label": "Diamond" },
        { "value": "heart", "label": "Heart" },
        { "value": "plus", "label": "Plus" },
        { "value": "arrow", "label": "Arrow" }
      ]
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color",
      "default": "#999999"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Welcome to our store"
        },
        {
          "type": "range",
          "id": "font_size",
          "label": "Font size",
          "default": 48,
          "min": 12,
          "max": 150,
          "step": 2,
          "unit": "px"
        }
      ]
    },
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "range",
          "id": "image_width",
          "label": "Image width",
          "default": 60,
          "min": 16,
          "max": 300,
          "step": 4,
          "unit": "px"
        },
        {
          "type": "range",
          "id": "image_height",
          "label": "Image height",
          "default": 60,
          "min": 16,
          "max": 300,
          "step": 4,
          "unit": "px"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Optional"
        }
      ]
    },
    {
      "type": "icon",
      "name": "Icon",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "star",
          "options": [
            { "value": "star", "label": "Star" },
            { "value": "heart", "label": "Heart" },
            { "value": "truck", "label": "Truck" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "globe", "label": "Globe" },
            { "value": "gift", "label": "Gift" },
            { "value": "fire", "label": "Fire" },
            { "value": "bolt", "label": "Lightning" },
            { "value": "smile", "label": "Smile" },
            { "value": "check", "label": "Check" }
          ]
        },
        {
          "type": "range",
          "id": "icon_size",
          "label": "Icon size",
          "default": 30,
          "min": 10,
          "max": 100,
          "step": 2,
          "unit": "px"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scrolling banner",
      "category": "Banners",
      "blocks": [
        { "type": "text" },
        { "type": "image" }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["custom.popups"]
  }
}
{% endschema %}
