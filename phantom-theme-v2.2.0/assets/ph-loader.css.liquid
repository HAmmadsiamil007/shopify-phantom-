/* ─── PHANTOM Signature Loader ────────────────────────────────────────────
 * Full-screen brand reveal with animated logo entrance, arc progress,
 * and circlular clip-path exit to page content.
 * Toggle: Theme settings → PHANTOM Motion → Show loader
 * Guards: prefers-reduced-motion | [data-disable-animations=true]
 * ──────────────────────────────────────────────────────────────────────── */

.ph-loader {
  position: fixed;
  inset: 0;
  z-index: 99999;
  display: flex;
  flex-direction: column;
  -webkit-box-align: center;
  align-items: center;
  -webkit-box-pack: center;
  justify-content: center;
  background: var(--ph-loader-bg, #ffffff);
  pointer-events: all;
  transition: opacity 400ms ease, visibility 400ms ease;
}

.ph-loader--hidden {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}

.ph-loader--exit {
  animation: ph-loader-exit 500ms cubic-bezier(0.65, 0, 0.35, 1) forwards;
}

.ph-loader__logo {
  max-width: var(--ph-loader-logo-max-w, 240px);
  max-height: var(--ph-loader-logo-max-h, 80px);
  margin-bottom: 32px;
  will-change: transform, opacity;
}

.ph-loader__logo img,
.ph-loader__logo svg {
  width: 100%;
  height: auto;
  display: block;
}

.ph-loader__logo--text {
  font-size: clamp(1.5rem, 4vw, 2.5rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--ph-loader-accent, #000000);
  white-space: nowrap;
}

.ph-loader__arc {
  position: relative;
  width: 48px;
  height: 48px;
}

.ph-loader__arc svg {
  display: block;
  width: 100%;
  height: 100%;
  transform: rotate(-90deg);
}

.ph-loader__arc-track {
  fill: none;
  stroke: var(--ph-loader-fg, #1c1d1d);
  stroke-width: 2;
  opacity: 0.08;
}

.ph-loader__arc-progress {
  fill: none;
  stroke: var(--ph-loader-accent, #000000);
  stroke-width: 2;
  stroke-linecap: round;
  stroke-dasharray: 113;
  stroke-dashoffset: 113;
}

.ph-loader__tagline {
  margin-top: 16px;
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--ph-loader-fg, #1c1d1d);
  opacity: 0;
  transition: opacity 600ms ease;
}

@media (prefers-reduced-motion: reduce) {
  .ph-loader__logo,
  .ph-loader__logo--text {
    opacity: 1;
    transform: none;
  }
  .ph-loader__arc-progress {
    stroke-dashoffset: 0;
  }
  .ph-loader__tagline {
    opacity: 0.5;
  }
  .ph-loader--exit {
    animation: none;
    opacity: 0;
    visibility: hidden;
  }
}

[data-disable-animations=true] .ph-loader__logo,
[data-disable-animations=true] .ph-loader__logo--text {
  opacity: 1;
  transform: none;
}

[data-disable-animations=true] .ph-loader__arc-progress {
  stroke-dashoffset: 0;
}

[data-disable-animations=true] .ph-loader__tagline {
  opacity: 0.5;
}

[data-disable-animations=true] .ph-loader--exit {
  animation: none;
  opacity: 0;
  visibility: hidden;
}
