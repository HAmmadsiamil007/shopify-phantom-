/* ─── PHANTOM Skeleton Loaders ────────────────────────────────────────
 * Layer 2: Loading state placeholders
 * Guard:  prefers-reduced-motion | [data-disable-animations=true]
 * ────────────────────────────────────────────────────────────────────── */

.ph-skeleton {
  position: relative;
  overflow: hidden;
  background: var(--ph-skeleton-bg, rgba(0,0,0,0.06));
  border-radius: 4px;
  pointer-events: none;
  user-select: none;
}

.ph-skeleton::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    90deg,
    transparent,
    var(--ph-shimmer-color, rgba(255,255,255,0.4)) 50%,
    transparent
  );
  transform: translateX(-100%);
  animation: ph-shimmer 1.5s infinite;
}

@keyframes ph-shimmer {
  100% { transform: translateX(100%); }
}

.ph-skeleton--text {
  height: 1em;
  margin-bottom: 0.5em;
  width: 100%;
}

.ph-skeleton--text-short {
  width: 60%;
}

.ph-skeleton--heading {
  height: 1.5em;
  margin-bottom: 0.75em;
  width: 70%;
}

.ph-skeleton--image {
  width: 100%;
  padding-bottom: 100%;
  height: 0;
}

.ph-skeleton--product {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  padding: 1rem;
  background: var(--ph-skeleton-card-bg, rgba(0,0,0,0.03));
  border-radius: 8px;
}

.ph-skeleton--section {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  padding: 2rem;
}

.ph-skeleton--avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  flex-shrink: 0;
}

.ph-skeleton--button {
  width: 120px;
  height: 40px;
  border-radius: var(--btn-radius, 4px);
}

.ph-skeleton--table-row {
  display: flex;
  gap: 12px;
  align-items: center;
  padding: 8px 0;
}

.ph-skeleton--table-row .ph-skeleton--text {
  flex: 1;
}

.ph-skeleton--table-row .ph-skeleton--text-short {
  flex: 0 0 60px;
}

@media (prefers-reduced-motion: reduce) {
  .ph-skeleton::after { animation: none; display: none; }
  .ph-skeleton { background: var(--ph-skeleton-bg, rgba(0,0,0,0.04)); }
}

[data-disable-animations=true] .ph-skeleton::after { animation: none; display: none; }

/* ─── Skeleton Container ──────────────────────────────────────────── */

.ph-skeleton--container {
  display: none;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.ph-skeleton--container.is-visible {
  display: block;
  opacity: 1;
}

.ph-skeleton--container\:visible {
  display: block;
  opacity: 1;
}

.ph-skeleton--container.is-hidden,
.ph-skeleton--container\:hidden {
  opacity: 0;
  pointer-events: none;
}

[data-disable-animations="true"] .ph-skeleton--container,
.ph-skeleton--container.ph-skeleton--instant {
  transition: none !important;
}

/* Overlay mode for collection grid and similar */
.ph-skeleton--container[data-skeleton="collection-grid"].is-visible {
  position: absolute;
  inset: 0;
  z-index: 3;
  background: var(--ph-colorBody, #fff);
}

#CollectionAjaxContent {
  position: relative;
}

/* Overlay mode for quiz product cards */
.ph-skeleton--container[data-skeleton="product-cards"].is-visible {
  position: absolute;
  inset: 0;
  z-index: 3;
  background: var(--ph-colorBody, #fff);
}

[data-quiz-cards] {
  position: relative;
}

/* Reset float-based grid for skeleton placeholder */
.ph-skeleton--container[data-skeleton="collection-grid"].is-visible ~ .grid__item {
  opacity: 0.3;
  pointer-events: none;
}

.ph-skeleton--container[data-skeleton="shipping-bar"].is-visible {
  display: block;
  opacity: 1;
}

.ph-skeleton--collection-sidebar::after {
  content: '';
  display: table;
  clear: both;
}
