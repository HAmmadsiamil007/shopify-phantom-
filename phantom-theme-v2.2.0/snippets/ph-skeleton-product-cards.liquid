<div class="ph-skeleton--product-cards" style="display:flex;gap:16px;padding:16px 0;flex-wrap:wrap;">
  {%- for i in (1..3) -%}
    <div class="ph-skeleton--product" style="flex:1;min-width:200px;">
      <div class="ph-skeleton ph-skeleton--image" style="width:100%;padding-bottom:100%;margin-bottom:12px;"></div>
      <div class="ph-skeleton ph-skeleton--heading" style="width:80%;margin-bottom:8px;"></div>
      <div class="ph-skeleton ph-skeleton--text-short" style="width:50%;"></div>
    </div>
  {%- endfor -%}
</div>
