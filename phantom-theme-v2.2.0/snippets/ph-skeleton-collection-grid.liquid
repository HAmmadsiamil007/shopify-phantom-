{%- assign columns = columns | default: 4 | times: 1 -%}
{%- assign total = columns | times: 2 -%}
{%- assign show_sidebar = show_sidebar | default: true -%}

<div class="ph-skeleton--section">
  {%- if show_sidebar -%}
    <div class="ph-skeleton--collection-sidebar medium-down--hide" style="float:left;width:220px;margin-right:24px;">
      <div class="ph-skeleton ph-skeleton--heading" style="margin-bottom:16px;"></div>
      <div class="ph-skeleton ph-skeleton--text" style="margin-bottom:8px;"></div>
      <div class="ph-skeleton ph-skeleton--text" style="margin-bottom:8px;"></div>
      <div class="ph-skeleton ph-skeleton--text" style="margin-bottom:8px;"></div>
      <div class="ph-skeleton ph-skeleton--text-short" style="margin-bottom:24px;"></div>
      <div class="ph-skeleton ph-skeleton--heading" style="margin-bottom:16px;"></div>
      <div class="ph-skeleton ph-skeleton--text" style="margin-bottom:8px;"></div>
      <div class="ph-skeleton ph-skeleton--text-short" style="margin-bottom:8px;"></div>
      <div class="ph-skeleton ph-skeleton--button" style="width:100%;height:44px;"></div>
    </div>
  {%- endif -%}

  <div class="ph-skeleton--collection-grid" style="overflow:hidden;">
    <div class="ph-skeleton--grid-row" style="display:flex;flex-wrap:wrap;gap:16px;margin:0 -8px;">
      {%- for i in (1..total) -%}
        <div class="ph-skeleton--product" style="flex:0 0 calc({{ 100 | divided_by: columns }}% - 16px);max-width:calc({{ 100 | divided_by: columns }}% - 16px);padding:0 8px;">
          <div class="ph-skeleton ph-skeleton--image" style="width:100%;padding-bottom:100%;margin-bottom:12px;"></div>
          <div class="ph-skeleton ph-skeleton--heading" style="width:80%;margin-bottom:8px;"></div>
          <div class="ph-skeleton ph-skeleton--text" style="width:60%;margin-bottom:4px;"></div>
          <div class="ph-skeleton ph-skeleton--text-short" style="width:40%;margin-bottom:12px;"></div>
          <div class="ph-skeleton ph-skeleton--button" style="width:100%;height:44px;"></div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>
